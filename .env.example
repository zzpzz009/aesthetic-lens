# ============================================================================
# AestheticLens 部署环境变量模板
# ============================================================================
# 使用方法：
#   1. 复制本文件为 .env  （Windows:  copy .env.example .env）
#   2. 按需取消注释 / 修改值
#   3. 在 app.py 顶部加入:  import config
#      （config.py 仅在变量未设置时填充默认值，不会覆盖已有环境变量）
#
# 所有变量均通过 os.environ 读取，setdefault 语义，命令行 / 系统级 export
# 优先级始终高于本文件。
# ============================================================================

# ----------------------------------------------------------------------------
# 路径
# ----------------------------------------------------------------------------
# 模型目录；留空时按以下顺序自动探测：
#   exe 同级 models/  >  PyInstaller _MEIPASS/models/  >  源码根/models/
# AESTHETICLENS_MODELS_DIR=

# WebView2 用户数据目录；留空时使用 %LOCALAPPDATA%\AestheticLens\webview2
# AESTHETICLENS_WEBVIEW2_STORAGE=

# ----------------------------------------------------------------------------
# 模型与推理
# ----------------------------------------------------------------------------
# 默认评分模型版本（v4.2 / v4.3 / v4.530；留空则取 AVAILABLE_MODELS 中最新）
# AESTHETICLENS_DEFAULT_MODEL=v4.530

# 强制使用 CPU（无 GPU 或驱动异常时设为 1）
# 0 = 优先 GPU，不可用时自动回退 CPU
# 1 = 强制 CPU
# AESTHETICLENS_FORCE_CPU=0

# ONNX Runtime 日志级别
# 0=VERBOSE 1=INFO 2=WARNING 3=ERROR 4=FATAL
# ORT_LOG_LEVEL=3

# ----------------------------------------------------------------------------
# 日志
# ----------------------------------------------------------------------------
# Python logging 根级别：DEBUG / INFO / WARNING / ERROR
# AESTHETICLENS_LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# WebView2（黑屏/启动失败时调整）
# ----------------------------------------------------------------------------
# 默认参数针对 Intel 核显/老驱动/受限账户做了兜底，常规环境保持默认即可
# WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS=--disable-gpu --disable-gpu-compositing --no-sandbox --disable-features=RendererCodeIntegrity
